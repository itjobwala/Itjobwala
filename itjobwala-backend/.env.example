# ── itJobwala Backend — Environment Variables ─────────────────────────────────
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# .env is git-ignored and never committed.
# For QA and production, set these vars directly in the Render service dashboard
# (Environment tab). Do NOT commit real values to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# Use port 6543 with ?pgbouncer=true for connection pooling in QA/prod.
# Use port 5432 (direct) for local development (migrations require direct connection).
#
# local:   postgresql://postgres:yourpassword@localhost:5432/itjobwala
# QA/prod: postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/itjobwala

# ── Auth ──────────────────────────────────────────────────────────────────────
# Legacy JWT secret (kept for backward compat until old sessions rotate out).
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Separate secrets for access tokens (15m) and refresh tokens (7d).
# These MUST be different from each other and from JWT_SECRET.
# Generate: openssl rand -hex 32
ACCESS_TOKEN_SECRET=replace-with-a-different-random-secret
REFRESH_TOKEN_SECRET=replace-with-yet-another-random-secret

# Token lifetimes (jsonwebtoken format: 15m, 1h, 7d, etc.)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Used for resume, profile photo, and certificate file uploads.
# Find these at: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. No trailing slashes.
#
# local:   http://localhost:3000
# QA:      https://qa-web.itjobwala.com
# prod:    https://itjobwala.com,https://www.itjobwala.com
CORS_ORIGINS=http://localhost:3000
