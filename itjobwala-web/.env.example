# ── itJobwala Frontend — Environment Variables ────────────────────────────────
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# .env.local is git-ignored and never committed.
# For QA and production, set these vars in your deployment platform (Render,
# Vercel, etc.) directly — do NOT commit real values to the repository.
#
# NEXT_PUBLIC_* vars are baked into the client bundle at build time.
# They must be set in the environment where `next build` runs.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL for all API calls. No trailing slash.
#
# local:      http://localhost:4001/api
# QA:         https://api-qa.itjobwala.com/api
# production: https://api.itjobwala.com/api
NEXT_PUBLIC_API_URL=http://localhost:4001/api

# ── Feature flags (optional) ──────────────────────────────────────────────────
# Set to "true" to load the auth navbar as a client-only dynamic import,
# bypassing SSR. Useful when debugging hydration mismatches in development.
# Default: false
NEXT_PUBLIC_DISABLE_AUTH_NAVBAR_SSR=false
